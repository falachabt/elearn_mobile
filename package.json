  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "generate-types": "pg-to-ts generate -c \"postgresql://postgres.yhznbitjlzeslvudbsil:a6AuGzmldCIXzyGV@aws-0-eu-central-1.pooler.supabase.com:5432/postgres\" -o ./types/type.ts",
    "android": "node ./scripts/switch-platform.js native && expo start --android",
    "ios": "node ./scripts/switch-platform.js native && expo start --ios",
    "web": "node ./scripts/switch-platform.js web && expo start --web",
    "build:web": "node ./scripts/switch-platform.js web && expo export --platform web",
    "build:native": "node ./scripts/switch-platform.js native && expo export",
    "build:development": "node ./scripts/switch-platform.js native eas build --profile development --platform android",
    "build:ios-simulator": "node ./scripts/switch-platform.js native eas build --profile ios-simulator --platform ios",
    "build:preview": "node ./scripts/switch-platform.js native eas build --profile preview --platform android",
    "build:production": "node ./scripts/switch-platform.js native eas build --profile production --platform android",
    "submit:production": "node ./scripts/switch-platform.js native eas submit --platform android",
    "deploy:web": "eas deploy",
    "deploy:web:prod": "eas deploy --prod",
    "test": "jest --watchAll",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo"
